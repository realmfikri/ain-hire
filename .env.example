# --- GCP / Vertex (reused from existing setup) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true

# --- Models ---
INTERVIEWER_MODEL=gemini-flash-latest
INTERVIEWER_MODEL_LOCATION=global
SCORER_MODEL=gemini-2.5-flash-001
SCORER_MODEL_LOCATION=global
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_LOCATION=us-central1

# --- Speech ---
STT_LANGUAGE=id-ID
STT_MODEL=chirp_2
STT_LOCATION=asia-southeast2
STT_RECOGNIZER=_
TTS_LANGUAGE=id-ID
TTS_VOICE_INTERVIEWER=id-ID-Chirp3-HD-Achernar
TTS_VOICE_PERSONA=id-ID-Standard-A

# --- BigQuery ---
BQ_DATASET=ain_hire
BQ_LOCATION=asia-southeast2
BQ_TABLE_SESSIONS=sessions
BQ_TABLE_SCORES=scores
BQ_TABLE_COMPETENCY=competency_scores
BQ_TABLE_TRANSCRIPTS=transcripts

# --- Storage ---
AUDIO_BUCKET=gs://your-gcp-project-id-ain-hire-data
STAGING_BUCKET=gs://your-gcp-project-id-ml-artifacts

# --- Client (Cloud Run) ---
CLOUD_RUN_REGION=asia-southeast2
INVITE_LINK_MODE=stub

# --- Agent Engine deploy ---
AGENT_ENGINE_REGION=asia-southeast2
AGENT_ENGINE_SERVICE_ACCOUNT=your-agent-engine-sa@your-gcp-project-id.iam.gserviceaccount.com

# --- Local/demo switches ---
# true runs with local JSON persistence and text fallback when GCP credentials are absent.
AIN_HIRE_USE_STUBS=true
LOCAL_DATA_DIR=.local_data
